  border-bottom: 1px solid rgba(212,164,76,0.3);
  transition: all 0.3s;
}
a:hover, .link-internal:hover {
  color: #fff;
  border-bottom-color: #fff;
  text-shadow: 0 0 8px rgba(212,164,76,0.5);
}
